# 기본값은 모의투자입니다. 실제 키와 계좌번호는 절대 Git에 추가하지 마세요.
KIS_IS_PAPER=true
MOCK_APP_KEY=
MOCK_APP_SECRET=
MOCK_ACCOUNT_NO=
MOCK_ACCOUNT_PRODUCT_CODE=

# 실전 주문은 아래 두 조건이 모두 충족되어야 합니다.
# KIS_IS_PAPER=false
# KIS_LIVE_TRADING_ENABLED=true
KIS_LIVE_TRADING_ENABLED=false

# 주문 안전 한도 (환경에 맞게 조정)
MAX_ORDER_AMOUNT_KRW=1000000
MAX_ORDER_AMOUNT_USD=1000
DAILY_BUY_LIMIT_KRW=3000000
DAILY_BUY_LIMIT_USD=3000
MAX_DAILY_LOSS_PERCENT=3
MAX_POSITIONS=10
MAX_DAILY_BUY_ORDERS=3
RISK_PER_TRADE_PERCENT=1
MAX_SPREAD_PERCENT=1
# KIS 호출 간격. 모의투자는 여유 있게 1.5초를 기본으로 사용합니다.
KIS_PAPER_REQUEST_INTERVAL_SECONDS=1.5
KIS_LIVE_REQUEST_INTERVAL_SECONDS=0.5
